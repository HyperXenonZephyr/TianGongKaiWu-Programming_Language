# ============================================
# Rust/Cargo 构建产物 - 绝对不要提交到Git！
# ============================================

# Cargo 构建目录
/target/
**/target/

# Cargo 调试构建
/debug/
**/debug/

# Cargo 锁文件（对于库项目，通常不提交）
Cargo.lock

# Cargo 构建缓存和增量编译
**/.cargo/
**/build/
**/dist/
**/out/

# ============================================
# 编译产物和可执行文件
# ============================================

# 可执行文件
*.exe
*.dll
*.so
*.dylib

# 调试信息文件
*.pdb
*.dbg
*.debug

# 静态库和动态库
*.a
*.lib
*.dll.a
*.dll.lib

# Rust 编译中间文件
*.rlib
*.rmeta
*.d
*.o
*.obj

# ============================================
# IDE 和编辑器文件
# ============================================

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains IDEs (RustRover, IntelliJ, CLion)
.idea/
*.iml
*.ipr
*.iws

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# ============================================
# 操作系统和临时文件
# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# 临时文件
*.tmp
*.temp
*.bak
*.backup
*.swp
*.swo
*~

# ============================================
# Rust 特定文件
# ============================================

# Rustfmt 备份文件
**/*.rs.bk

# Cargo mutants 测试数据
**/mutants.out*/

# Rust 覆盖率数据
*.profraw
*.gcda
*.gcno

# ============================================
# 日志和测试输出
# ============================================

# 日志文件
*.log
logs/

# 测试输出
test-output/
coverage/

# ============================================
# 环境文件和配置
# ============================================

# 环境变量文件
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 本地配置文件
config.local.*
settings.local.*

# ============================================
# 文档生成
# ============================================

# Rustdoc 生成
/doc/
**/doc/

# ============================================
# 其他构建系统
# ============================================

# Makefile 产物
*.deps
*.make
*.cmake

# ============================================
# 安全警告
# ============================================
# 注意：此文件已配置为阻止提交 target 目录
# 如果意外添加了 target 文件，使用以下命令移除：
# git rm -r --cached target/
# git commit -m "移除误添加的target目录"
